{
	"version": "1.17",
	"label": "app.name",
	"paths": ["help"],

	"architecture": {"engine": "starlark", "version": 4},
	"execute": ["help.star"],

	"icons": [
		{"action": "", "label": "app.name", "file": "images/icon.svg"}
	],

	"actions": {
		"": {"file": "web/dist/index.html"},
		"assets": {"files": "web/dist/assets"},
		"images": {"files": "web/dist/images"},
		"-/visit": {"function": "action_visit"},
		"-/prepare": {"function": "action_prepare"},
		"-/contribute": {"function": "action_contribute"},
		"-/document/get": {"function": "action_document_get", "public": true},
		"document/rules": {"file": "web/dist/index.html"},
		"document/terms": {"file": "web/dist/index.html"},
		"document/privacy": {"file": "web/dist/index.html"}
	}
}
